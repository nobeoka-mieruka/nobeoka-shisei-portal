# Vite出力のハッシュ付きJS/CSSは内容が変わればファイル名も変わるため、長期キャッシュして問題ない。
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ロゴ・共通OGP画像などの静的画像。中身は変わり得るため、長期キャッシュにはしない。
/images/*
  Cache-Control: public, max-age=604800

/og/*
  Cache-Control: public, max-age=86400

/og-image.png
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=604800

# sitemap.xml・robots.txtはビルドのたびに内容が変わり得るため、短めのキャッシュにする。
/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

# 全ページ共通のセキュリティ関連ヘッダー。
# index.html（SPAのため実質すべてのルートで配信される）は、ここでは長期キャッシュを指定しない。
#
# Content-Security-Policyのscript-srcは、React 19のストリーミングSSR（プリレンダリング）が
# 全ページで出力する固定2種類のインラインscript（$RC等の描画完了通知、requestAnimationFrameの
# 計測用コード）だけをsha256ハッシュで許可し、'unsafe-inline'は使わない。
# React/Viteのバージョン更新でこの生成コードが変わるとハッシュが一致しなくなるが、その場合も
# クライアント側のReact（createRoot）がページ全体を再描画するため表示は壊れない
# （dist/*.htmlの該当scriptを再取得し、ハッシュを再計算のうえ更新すること）。
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-7mu4H06fwDCjmnxxr/xNHyuQC6pLTHr4M2E4jXw5WZs=' 'sha256-QAlSewaQLi/NPCznjAZSyvQ72heD0VdxmNDDkZeCxgc=' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'
